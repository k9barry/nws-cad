# Vendor directory
/vendor/

# Environment files
.env

# Dozzle simple-auth users file (contains bcrypt-hashed credentials)
/docker/dozzle/users.yml

# Runtime state lives under var/ (see src/Config.php paths)
# Log files
/var/log/*
!/var/log/.gitkeep

# Watch folder files
/var/watch/*
!/var/watch/.gitkeep

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Database data
/var/data/mysql/*
!/var/data/mysql/.gitkeep
/var/data/postgres/*
!/var/data/postgres/.gitkeep


# Composer lock (optional - uncomment if needed)
# composer.lock

# Test coverage reports
/coverage/
.phpunit.cache/
.phpunit.result.cache

# Test artifacts
/tests/tmp/

# Database backups (keep locally, don't commit)
/var/backups/*
!/var/backups/.gitkeep
