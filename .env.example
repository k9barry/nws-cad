# Database Configuration
# Supported values: mysql, pgsql
DB_TYPE=mysql

# Docker Compose profile selector. Must match DB_TYPE so only the active
# database container starts (the other one is gated behind its profile).
# Allowed values: mysql, pgsql
COMPOSE_PROFILES=mysql

# Timezone for both PHP (date.timezone) and the container (TZ env var).
# Used at build time (passed as ARG to both Dockerfiles) and at runtime
# (passed as env to the app and api services). Must be an IANA tz name.
TZ=America/Indianapolis

# Backup configuration
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# MySQL Configuration (used when DB_TYPE=mysql)
MYSQL_HOST=mysql
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=nws_cad
MYSQL_USER=nws_user
MYSQL_PASSWORD=nws_password_change_me
MYSQL_PORT=3306

# PostgreSQL Configuration (used when DB_TYPE=pgsql)
POSTGRES_HOST=postgres
POSTGRES_DB=nws_cad
POSTGRES_USER=nws_user
POSTGRES_PASSWORD=nws_password_change_me
POSTGRES_PORT=5432

# PHP Configuration
PHP_VERSION=8.3
PHP_MEMORY_LIMIT=512M

# Application Configuration
APP_ENV=development
APP_DEBUG=true
APP_LOGS_ENABLED=true
WATCH_FOLDER=/var/www/watch
LOG_LEVEL=debug

# File Watcher Configuration
WATCHER_INTERVAL=5
WATCHER_FILE_PATTERN=*.xml

# Dozzle Configuration (Docker Log Viewer)
# Authentication is handled via docker/dozzle/users.yml (simple-auth, bcrypt-
# hashed). DOZZLE_USERNAME / DOZZLE_PASSWORD env vars are NOT supported in
# Dozzle v7+ and are silently ignored. To create or rotate the users file:
#   docker run --rm amir20/dozzle:latest generate <user> --password <pw> \
#     --name <display> --email <email> > docker/dozzle/users.yml
DOZZLE_PORT=8081

# =============================================================================
# Notifications (v1.2.0 — nws-endpoints consolidation)
# =============================================================================
# Delta-time gate: events older than this many seconds are NOT notified.
NOTIFICATION_DELTA_SECONDS=900

# ntfy.sh — required when an ntfy channel is enabled in notification_channels.
# Example: NTFY_AUTH_TOKEN=Bearer tk_yourtokenhere
NTFY_AUTH_TOKEN=
NTFY_BASE_URL=

# Pushover — required when a pushover channel is enabled.
PUSHOVER_TOKEN=
PUSHOVER_USER=
PUSHOVER_BASE_URL=https://api.pushover.net/1/messages.json
